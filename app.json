{
  "expo": {
    "name": "مُصلِّي",
    "slug": "musley",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "owner": "nbare1997",
    "splash": {
      "image": "./splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nbare.moslee",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "يستخدم التطبيق موقعك لتحديد اتجاه القبلة وأوقات الصلاة"
      }
    },
    "android": {
      "package": "com.nbare.moslee",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يستخدم التطبيق موقعك لتحديد اتجاه القبلة وأوقات الصلاة"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a5653f19-9109-4379-8146-211d621f3ad8"
      }
    }
  }
}
